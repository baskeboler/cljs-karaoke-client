{
    "name": "cljs-karaoke-client",
    "repository": "https://github.com/baskeboler/cljs-karaoke-client",
    "version": "1.5.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "build": "npm run release",
        "test": "echo \"Error: no test specified\" && exit 1",
        "cljs-watch": "shadow-cljs watch app lambda-images",
        "compile": "shadow-cljs compile app lambda-images",
        "release": "shadow-cljs release app lambda-images",
        "start": "concurrently 'npm:cljs-watch' 'npm:css-watch'",
        "copy-webfonts": "cp -rf ./node_modules/@fortawesome/fontawesome-free/webfonts ./public/",
        "css-build": "sass --no-source-map --quiet-deps --load-path=node_modules resources/sass/main.scss public/css/main.css",
        "css-watch": "sass --watch --quiet-deps --load-path=node_modules resources/sass/main.scss:public/css/main.css"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bulma-tooltip": "^2.0.2",
        "chart.js": "2.9.4",
        "create-react-class": "^15.7.0",
        "highlight.js": "10.4.1",
        "mongodb-stitch-browser-sdk": "^4.8.0",
        "path": "^0.12.7",
        "react": "^16.14.0",
        "react-awesome-button": "^6.5.1",
        "react-dom": "^16.14.0",
        "react-flip-move": "^3.0.4",
        "react-highlight.js": "^1.0.7",
        "shake.js": "^1.2.2"
    },
    "devDependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "bulma": "^1.0.4",
        "concurrently": "^5.3.0",
        "netlify-cli": "^24.9.0",
        "netlify-lambda": "^2.0.16",
        "sass": "^1.93.2",
        "shadow-cljs": "^2.11.8"
    }
}
